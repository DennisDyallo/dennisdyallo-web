---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  jsonLd?: object;
}

const {
  title = 'Dennis Dyall',
  description = 'Developer, artist manager, and creative practitioner based in Gothenburg, Sweden.',
  ogImage = '/og-image.jpg',
  canonicalUrl,
  jsonLd,
} = Astro.props;

const siteUrl = 'https://dyallo.se';
const fullTitle = title === 'Dennis Dyall' ? title : `${title} — Dennis Dyall`;
const canonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

// Person JSON-LD (preserved from legacy)
const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Dennis Dyall',
  jobTitle: ['Senior Software Engineer', 'Artist Manager', 'Zen Coach'],
  worksFor: { '@type': 'Organization', name: 'Yubico' },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Gothenburg',
    addressCountry: 'SE',
  },
  url: 'https://dyallo.se',
  sameAs: [
    'https://github.com/DennisDyallo',
    'https://www.linkedin.com/in/dennis-dyallo',
    'https://www.instagram.com/ddyallo',
    'https://www.facebook.com/ddyallo',
    'https://echological.fm',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Dennis Dyall" />
    <meta name="theme-color" content="#E0531C" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Dennis Dyall" />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fonts (preconnect) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon (placeholder - will be replaced with Rupicola SVG) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Person JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />

    <!-- Page-specific JSON-LD -->
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <!-- Umami Analytics (preserved verbatim) -->
    <script
      defer
      src="https://analytics.dyallo.se/script.js"
      data-website-id="363c559e-8df6-4db0-ac35-d5bff81d9e92"></script>

    <!-- Theme script (runs before paint) -->
    <script is:inline>
      const getTheme = () => {
        if (typeof localStorage !== 'undefined') {
          const stored = localStorage.getItem('theme');
          if (stored) return stored;
        }
        return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      };
      document.documentElement.setAttribute('data-theme', getTheme());
    </script>
  </head>
  <body>
    {Astro.url.pathname !== '/' && (
      <header class="site-header">
        <div class="site-header-inner">
          <a href="/" class="site-home" aria-label="Back to home">
            <span class="site-home-arrow" aria-hidden="true">←</span>
            <span class="site-home-mark">dyallo.se</span>
          </a>
          <nav class="site-nav" aria-label="Primary">
            <a href="/about" class:list={['nav-link', { active: Astro.url.pathname.startsWith('/about') }]}>About</a>
            <a href="/now" class:list={['nav-link', { active: Astro.url.pathname.startsWith('/now') }]}>Now</a>
            <a href="/blog" class:list={['nav-link', { active: Astro.url.pathname.startsWith('/blog') }]}>Blog</a>
            <a href="/library" class:list={['nav-link', { active: Astro.url.pathname.startsWith('/library') }]}>Library</a>
            <a href="/projects" class:list={['nav-link', { active: Astro.url.pathname.startsWith('/projects') }]}>Projects</a>
            <button id="theme-toggle" class="nav-toggle" aria-label="Toggle light/dark mode" title="Toggle theme"></button>
          </nav>
        </div>
      </header>
    )}

    <slot />

    <style is:global>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: color-mix(in srgb, var(--bg) 92%, transparent);
        backdrop-filter: saturate(180%) blur(10px);
        -webkit-backdrop-filter: saturate(180%) blur(10px);
        border-bottom: 1px solid var(--border);
      }
      .site-header-inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0.7rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }
      .site-home {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        color: var(--ink);
        font-family: var(--font-serif);
        font-size: 1rem;
        font-weight: 500;
        text-decoration: none;
        letter-spacing: 0.01em;
      }
      .site-home-arrow {
        color: var(--primary);
        transition: transform 0.2s ease;
      }
      .site-home:hover .site-home-arrow { transform: translateX(-2px); }
      .site-home:hover .site-home-mark { color: var(--primary); }
      .site-nav {
        display: inline-flex;
        align-items: center;
        gap: 1.25rem;
        font-family: var(--font-sans);
        font-size: 0.88rem;
      }
      .nav-link {
        color: var(--muted);
        text-decoration: none;
        padding: 0.2rem 0;
        border-bottom: 1px solid transparent;
        transition: color 0.2s, border-color 0.2s;
      }
      .nav-link:hover { color: var(--ink); }
      .nav-link.active {
        color: var(--ink);
        border-bottom-color: var(--primary);
      }
      .nav-toggle {
        background: transparent;
        border: 1px solid var(--ink);
        color: var(--ink);
        border-radius: 4px;
        padding: 0.25rem 0.5rem;
        cursor: pointer;
        font-size: 0.85rem;
        line-height: 1;
        margin-left: 0.5rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.9rem;
        height: 1.9rem;
      }
      .nav-toggle::before { content: '☾'; }
      [data-theme='dark'] .nav-toggle::before { content: '☀'; }
      .nav-toggle:hover, .nav-toggle:focus-visible {
        background: var(--primary);
        color: var(--bg);
        border-color: var(--primary);
        outline: none;
      }
      @media (max-width: 640px) {
        .site-header-inner { padding: 0.6rem 1rem; flex-wrap: wrap; gap: 0.5rem; }
        .site-nav { gap: 0.75rem; font-size: 0.82rem; }
        .nav-link { padding: 0.15rem 0; }
      }
    </style>

    <!-- Theme toggle script -->
    <script>
      function initThemeToggle() {
        const toggle = document.getElementById('theme-toggle');
        if (!toggle) return;

        toggle.addEventListener('click', () => {
          const current = document.documentElement.getAttribute('data-theme');
          const next = current === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
        });
      }

      // Run on load and after navigation
      document.addEventListener('DOMContentLoaded', initThemeToggle);
      document.addEventListener('astro:after-swap', initThemeToggle);
    </script>
  </body>
</html>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Coaching" description="Zen coaching, meditation facilitation, and inner work.">
  <div class="container">
    <h1>Coaching</h1>
    <div class="content">
      <p>
        Zen coaching rooted in Vipassana, yoga, and contemplative practice. Work for individuals
        navigating change, creative blocks, or deeper self-understanding.
      </p>
      <p>
        <em>Full service page with booking CTA coming in Phase 2.</em>
      </p>
    </div>
  </div>

  <style>
    .container {
      max-width: var(--reading-width);
      margin: 0 auto;
      padding: var(--space-2xl) var(--space-lg);
    }

    h1 {
      font-size: 2.5rem;
      margin-bottom: var(--space-xl);
    }

    .content p {
      font-size: 1.1rem;
      line-height: 1.7;
      margin-bottom: var(--space-lg);
      color: var(--muted);
    }

    .content em {
      color: var(--muted);
      font-style: italic;
    }
  </style>
</BaseLayout>

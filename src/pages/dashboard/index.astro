---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import RupicolaMark from '../../components/RupicolaMark.astro';
import dashboardData from '../../data/vault-dashboard.json';

type ActivityType =
  | 'sias-lens'
  | 'ingestion'
  | 'journal'
  | 'dream'
  | 'message'
  | 'conversation'
  | 'project'
  | 'knowledge'
  | 'daemon-update'
  | 'daemon-status'
  | 'repo-activity'
  | 'registry-project'
  | 'registry-service';

type ActivityItem = {
  id: string;
  type: ActivityType;
  title: string;
  subtitle: string;
  timestamp: string;
  path: string;
  tags: string[];
  excerpt: string;
  obsidianUrl: string;
  sourceUrl: string;
  person?: 'oren' | 'watashi';
  status?: 'ok' | 'stale' | 'unknown' | 'down';
  search: {
    title: string;
    headings: string;
    bold: string;
    tags: string;
    path: string;
    body: string;
  };
};

const items = (dashboardData.items as ActivityItem[]).sort(
  (a, b) => Date.parse(b.timestamp) - Date.parse(a.timestamp),
);
const generatedAt = new Date(dashboardData.generatedAt);
const recentItems = items.slice(0, 18);
const lanes: Array<{ type: ActivityType; label: string; glyph: string; hint: string }> = [
  { type: 'sias-lens', label: "Sia's Lens", glyph: '◇', hint: 'Oracle updates' },
  { type: 'ingestion', label: 'Ingestions', glyph: '▣', hint: 'New vault loot' },
  { type: 'journal', label: 'Journal', glyph: '✎', hint: 'Captain logs' },
  { type: 'dream', label: 'Dream Realm', glyph: '☾', hint: 'Night signals' },
  { type: 'message', label: 'Messages', glyph: '✉', hint: 'Message Sync' },
  { type: 'conversation', label: 'Conversations', glyph: '☵', hint: 'Companions' },
  { type: 'project', label: 'Projects', glyph: '⚔', hint: 'Campaigns' },
  { type: 'knowledge', label: 'Knowledge', glyph: '✦', hint: 'Codex' },
  { type: 'daemon-update', label: 'Daemon Updates', glyph: '⚙', hint: 'Patch notes' },
  { type: 'daemon-status', label: 'Daemons', glyph: '♥', hint: 'Party frames' },
  { type: 'registry-project', label: 'Registry', glyph: '⌘', hint: 'Canonical map' },
  { type: 'registry-service', label: 'Services', glyph: '◈', hint: 'System substrate' },
  { type: 'repo-activity', label: 'Repo Activity', glyph: '⌁', hint: 'Latest commits' },
];

const counts = lanes.map((lane) => ({ ...lane, count: items.filter((item) => item.type === lane.type).length }));
const latestLens = items.find((item) => item.type === 'sias-lens');
const conversations = items.filter((item) => item.type === 'conversation').slice(0, 4);
const messages = items.filter((item) => item.type === 'message').slice(0, 5);
const projects = items.filter((item) => item.type === 'project').slice(0, 5);
const daemons = items.filter((item) => item.type === 'daemon-status').slice(0, 10);
const registryProjects = items.filter((item) => item.type === 'registry-project').slice(0, 7);
const registryServices = items.filter((item) => item.type === 'registry-service').slice(0, 6);
const repoActivity = items.filter((item) => item.type === 'repo-activity').slice(0, 5);
function isPeopleDossier(item: ActivityItem) {
  return item.path === 'Knowledge/People.md' || item.path.startsWith('Knowledge/People/') || item.tags.includes('type/person') || item.tags.includes('person');
}
const peopleDossierCount = items.filter(isPeopleDossier).length;
const searchPayload = items.map((item) => ({
  id: item.id,
  type: item.type,
  title: item.title,
  subtitle: item.subtitle,
  timestamp: item.timestamp,
  path: item.path,
  tags: item.tags,
  excerpt: item.excerpt,
  obsidianUrl: item.obsidianUrl,
  sourceUrl: item.sourceUrl,
  person: item.person,
  status: item.status,
  search: {
    title: item.search.title,
    headings: item.search.headings,
    bold: item.search.bold,
    tags: item.search.tags,
    path: item.search.path,
    body: item.search.body.slice(0, 1800),
  },
}));
const searchPayloadJson = JSON.stringify(searchPayload)
  .replace(/</g, '\\u003c')
  .replace(/>/g, '\\u003e')
  .replace(/&/g, '\\u0026')
  .replace(/\u2028/g, '\\u2028')
  .replace(/\u2029/g, '\\u2029');

function formatDate(value: string | Date) {
  const date = typeof value === 'string' ? new Date(value) : value;
  return date.toLocaleDateString('en-GB', { month: 'short', day: '2-digit', year: 'numeric' });
}

function formatTime(value: string | Date) {
  const date = typeof value === 'string' ? new Date(value) : value;
  return date.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
}

function typeLabel(type: ActivityType) {
  return lanes.find((lane) => lane.type === type)?.label ?? type;
}
---

<DashboardLayout
  title="Vault Quest Log"
  description="Private Rupicola OS dashboard for Obsidian vault activity."
  canonicalUrl="https://vault.dyallo.se/dashboard/"
>
  <main class="dashboard-shell" data-pagefind-ignore>
    <section class="hero-panel" aria-labelledby="dashboard-title">
      <div class="scanline" aria-hidden="true"></div>
      <div class="hero-topline">
        <span class="boot-chip">RUPICOLA OS v0.88</span>
        <span class="boot-chip purple">PRIVATE SAVE FILE</span>
        <span class="boot-chip">SYNC {formatDate(generatedAt)} {formatTime(generatedAt)}</span>
      </div>
      <div class="hero-grid">
        <div class="hero-mark" aria-hidden="true"><RupicolaMark size={112} /></div>
        <div>
          <p class="eyebrow">Vault command center</p>
          <h1 id="dashboard-title">Vault Quest Log</h1>
          <p class="hero-copy">
            Recent activity, message-sync drops, companion conversations, dream realm signals, daemon party frames, registry projects, services, and Sia's oracle updates in one private retro console.
          </p>
        </div>
        <div class="save-stats" aria-label="Vault stats">
          <div><strong>{items.length}</strong><span>indexed entries</span></div>
          <div><strong>{counts.filter((lane) => lane.count > 0).length}</strong><span>active lanes</span></div>
          <div><strong>30m</strong><span>regen target</span></div>
        </div>
      </div>
    </section>

    <section class="search-console" aria-label="Vault omni search">
      <div class="console-titlebar">
        <span>COMMAND.COM</span>
        <span>grep-style relevance</span>
      </div>
      <label class="search-label" for="vault-search">Omni Search</label>
      <div class="search-row">
        <span class="prompt">/search</span>
        <input
          id="vault-search"
          type="search"
          autocomplete="off"
          spellcheck="false"
          placeholder='type:message whatsapp after:2026-06 or watashi attraction'
        />
        <button id="clear-search" type="button">CLR</button>
      </div>
      <p class="search-help">
        Shortcuts: <kbd>/</kbd> focus, <kbd>Tab</kbd> complete, <kbd>Esc</kbd> clear. Filters: <code>type:message</code>, <code>type:registry-project</code>, <code>type:registry-service</code>, <code>dossier:people</code>, <code>person:oren</code>, <code>after:2026-06-01</code>.
      </p>
      <div id="search-results" class="search-results" aria-live="polite"></div>
    </section>

    <section class="lane-grid" aria-label="Activity lanes">
      {counts.map((lane) => (
        <button class="lane-card" type="button" data-lane={lane.type}>
          <span class="lane-glyph">{lane.glyph}</span>
          <span class="lane-text"><strong>{lane.label}</strong><em>{lane.hint}</em></span>
          <span class="lane-count">{lane.count}</span>
        </button>
      ))}
      <button class="lane-card dossier-card" type="button" data-dossier="people">
        <span class="lane-glyph">◎</span>
        <span class="lane-text"><strong>People / Dossiers</strong><em>Person files</em></span>
        <span class="lane-count">{peopleDossierCount}</span>
      </button>
    </section>

    <section class="main-grid">
      <div class="quest-log">
        <div class="section-heading">
          <p>Primary feed</p>
          <h2>Recent Activity</h2>
        </div>
        <div class="activity-list" id="activity-list">
          {recentItems.map((item) => (
            <article class:list={['activity-card', `type-${item.type}`]} data-type={item.type}>
              <div class="card-rarity">{typeLabel(item.type)}</div>
              <div class="card-main">
                <time datetime={item.timestamp}>{formatDate(item.timestamp)} · {formatTime(item.timestamp)}</time>
                <h3>{item.title}</h3>
                <p class="subtitle">{item.subtitle}</p>
                <p class="excerpt">{item.excerpt}</p>
                <p class="path">{item.path}</p>
                <div class="card-actions">
                  <a href={item.sourceUrl}>Open inline</a>
                  <a href={item.obsidianUrl}>Open in Vault</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <aside class="side-panels" aria-label="Dashboard side panels">
        <section class="side-panel oracle">
          <button class="panel-title panel-title-button" type="button" data-panel-query="type:sias-lens" aria-pressed="false">Oracle Says</button>
          {latestLens ? (
            <a href={latestLens.sourceUrl}>
              <time datetime={latestLens.timestamp}>{formatDate(latestLens.timestamp)}</time>
              <strong>{latestLens.title}</strong>
              <span>{latestLens.excerpt}</span>
            </a>
          ) : <p>No lens report indexed.</p>}
        </section>

        <section class="side-panel">
          <button class="panel-title panel-title-button" type="button" data-panel-query="type:conversation" aria-pressed="false">Companions</button>
          {conversations.map((item) => (
            <a class="mini-row" href={item.sourceUrl}>
              <span class="avatar">{item.person === 'watashi' ? 'W' : 'O'}</span>
              <span><strong>{item.person === 'watashi' ? 'Watashi' : 'Oren'}</strong><em>{item.subtitle}</em></span>
            </a>
          ))}
        </section>

        <section class="side-panel">
          <button class="panel-title panel-title-button" type="button" data-panel-query="type:message" aria-pressed="false">Message Sync</button>
          {messages.map((item) => (
            <a class="mini-row" href={item.sourceUrl}>
              <span class="avatar">✉</span>
              <span><strong>{item.title}</strong><em>{item.subtitle}</em></span>
            </a>
          ))}
        </section>

        <section class="side-panel">
          <button class="panel-title panel-title-button" type="button" data-panel-query="type:project" aria-pressed="false">Active Campaigns</button>
          {projects.map((item) => (
            <a class="mini-row" href={item.sourceUrl}>
              <span class="pixel-dot"></span>
              <span><strong>{item.title}</strong><em>{item.path}</em></span>
            </a>
          ))}
        </section>

        <section class="side-panel daemon-panel">
          <button class="panel-title panel-title-button" type="button" data-panel-query="type:daemon-status" aria-pressed="false">Daemon Party</button>
          {daemons.map((item) => (
            <a class="daemon-row" href={item.sourceUrl}>
              <span class:list={['health', item.status === 'down' ? 'down' : item.status === 'stale' ? 'stale' : item.status === 'unknown' ? 'unknown' : 'ok']}></span>
              <span><strong>{item.title}</strong><em>{item.subtitle}</em></span>
            </a>
          ))}
        </section>

        <section class="side-panel registry-panel">
          <button class="panel-title panel-title-button" type="button" data-panel-query="type:registry-project" aria-pressed="false">Canonical Map</button>
          {registryProjects.map((item) => (
            <a class="mini-row" href={item.sourceUrl}>
              <span class="avatar">⌘</span>
              <span><strong>{item.title}</strong><em>{item.subtitle}</em></span>
            </a>
          ))}
        </section>

        <section class="side-panel registry-panel">
          <button class="panel-title panel-title-button" type="button" data-panel-query="type:registry-service" aria-pressed="false">Services + Health</button>
          {registryServices.map((item) => (
            <a class="daemon-row" href={item.sourceUrl}>
              <span class:list={['health', item.status === 'down' ? 'down' : item.status === 'stale' ? 'stale' : item.status === 'unknown' ? 'unknown' : 'ok']}></span>
              <span><strong>{item.title}</strong><em>{item.subtitle}</em></span>
            </a>
          ))}
        </section>

        <section class="side-panel">
          <button class="panel-title panel-title-button" type="button" data-panel-query="type:repo-activity" aria-pressed="false">Repo Pulse</button>
          {repoActivity.map((item) => (
            <a class="mini-row" href={item.sourceUrl}>
              <span class="avatar">⌁</span>
              <span><strong>{item.title}</strong><em>{item.subtitle}</em></span>
            </a>
          ))}
        </section>
      </aside>
    </section>
  </main>

  <script is:inline set:html={`window.__VAULT_DASHBOARD__ = ${searchPayloadJson};`} />
  <script is:inline>
    const items = window.__VAULT_DASHBOARD__ || [];
    const input = document.getElementById('vault-search');
    const clear = document.getElementById('clear-search');
    const results = document.getElementById('search-results');
    const activityList = document.getElementById('activity-list');

    const labels = {
      'sias-lens': "Sia's Lens",
      ingestion: 'Ingestion',
      journal: 'Journal',
      dream: 'Dream',
      message: 'Messages',
      conversation: 'Conversation',
      project: 'Project',
      knowledge: 'Knowledge',
      'daemon-update': 'Daemon Update',
      'daemon-status': 'Daemon Status',
      'repo-activity': 'Repo Activity',
      'registry-project': 'Registry Project',
      'registry-service': 'Registry Service',
    };
    const filterNames = ['type', 'person', 'after', 'before', 'dossier'];
    const typeValues = Object.keys(labels).sort((a, b) => a.length - b.length || a.localeCompare(b));
    const personValues = [...new Set(items.map((item) => item.person).filter(Boolean))].sort();
    const dossierValues = ['people'];

    function parseQuery(query) {
      const quoted = [...query.matchAll(/"([^"]+)"/g)].map((match) => match[1]);
      const withoutQuoted = query.replace(/"([^"]+)"/g, ' ');
      const filters = {};
      const terms = [...quoted];
      for (const raw of withoutQuoted.split(/\s+/).filter(Boolean)) {
        const filter = raw.match(/^(type|person|after|before|dossier):(.+)$/i);
        if (filter) filters[filter[1].toLowerCase()] = filter[2].toLowerCase();
        else terms.push(raw);
      }
      return { terms: terms.map((term) => term.toLowerCase()), filters };
    }

    function matchesFilters(item, filters) {
      if (filters.type) {
        const aliases = { lens: 'sias-lens', dreams: 'dream', messages: 'message', ingestions: 'ingestion', daemon: 'daemon-status', registry: 'registry-project', service: 'registry-service', services: 'registry-service', repo: 'repo-activity' };
        const wanted = aliases[filters.type] || filters.type;
        if (!item.type.includes(wanted)) return false;
      }
      if (filters.person && item.person !== filters.person) return false;
      if (filters.dossier) {
        const wanted = filters.dossier;
        const isPeople = item.path === 'Knowledge/People.md' || item.path.startsWith('Knowledge/People/') || item.tags.includes('type/person') || item.tags.includes('person');
        if (!['people', 'person', 'persons', 'dossiers'].includes(wanted) || !isPeople) return false;
      }
      if (filters.after && Date.parse(item.timestamp) < Date.parse(filters.after)) return false;
      if (filters.before && Date.parse(item.timestamp) > Date.parse(filters.before)) return false;
      return true;
    }

    function scoreItem(item, terms) {
      if (terms.length === 0) return 1;
      const fields = [
        [item.search.title, 80],
        [item.title, 70],
        [item.subtitle, 48],
        [item.search.headings, 42],
        [item.search.tags, 34],
        [item.search.path, 30],
        [item.path, 26],
        [item.search.bold, 24],
        [item.excerpt, 16],
        [item.search.body, 6],
      ];
      let score = 0;
      for (const term of terms) {
        let matched = false;
        for (const [value, weight] of fields) {
          const haystack = String(value || '').toLowerCase();
          if (haystack.includes(term)) {
            score += weight;
            matched = true;
          }
        }
        if (!matched) return 0;
      }
      const ageDays = Math.max(0, (Date.now() - Date.parse(item.timestamp)) / 86_400_000);
      return score + Math.max(0, 12 - ageDays / 14);
    }

    function escapeHtml(value) {
      return String(value).replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[char]);
    }

    function matchReasons(item, terms) {
      if (terms.length === 0) return [];
      const fields = [
        ['title', [item.search.title, item.title, item.subtitle]],
        ['heading', [item.search.headings]],
        ['tag', [item.search.tags]],
        ['path', [item.search.path, item.path]],
        ['body', [item.search.bold, item.excerpt, item.search.body]],
      ];
      return fields
        .filter(([, values]) => terms.some((term) => values.some((value) => String(value || '').toLowerCase().includes(term))))
        .map(([label]) => label);
    }

    function scoreLabel(score, terms) {
      if (terms.length === 0) return 'filter match';
      return `score ${Math.round(score)}`;
    }

    function completeFromList(token, values) {
      return values.find((value) => value.startsWith(token) && value !== token) || '';
    }

    function safeTitleTokens(title) {
      return String(title || '')
        .toLowerCase()
        .split(/\s+/)
        .map((token) => token.replace(/^[^a-z0-9-]+|[^a-z0-9-]+$/g, ''))
        .filter((token) => token && !token.includes(':') && !token.includes('"'))
        .filter((token) => !filterNames.some((name) => token.startsWith(`${name}:`)));
    }

    function titleCompletion(stem) {
      if (!stem || stem.includes(':') || stem.includes('"')) return '';
      const normalizedStem = stem.toLowerCase().trim().replace(/\s+/g, ' ');
      if (!normalizedStem || filterNames.some((name) => normalizedStem.split(/\s+/).some((token) => token.startsWith(`${name}:`)))) return '';
      const candidates = [];
      for (const item of items) {
        const tokens = safeTitleTokens(item.title);
        for (let length = 1; length <= tokens.length; length += 1) {
          const prefix = tokens.slice(0, length).join(' ');
          if (prefix.startsWith(normalizedStem) && prefix !== normalizedStem) candidates.push(prefix);
        }
      }
      return candidates.sort((a, b) => a.length - b.length || a.localeCompare(b))[0] || '';
    }

    function trailingFreeRunStart(query) {
      const tokens = [...query.matchAll(/\S+/g)];
      let start = null;
      for (let index = tokens.length - 1; index >= 0; index -= 1) {
        const token = tokens[index][0];
        if (token.includes(':') || token.includes('"')) break;
        start = tokens[index].index;
      }
      return start;
    }

    function tabCompletion(query) {
      const tokenMatch = query.match(/\S+$/);
      if (!tokenMatch || /\s$/.test(query)) return '';
      const token = tokenMatch[0];
      const tokenStart = tokenMatch.index;
      const lowerToken = token.toLowerCase();
      const filterMatch = lowerToken.match(/^(type|person|after|before|dossier):(.*)$/);

      if (filterMatch) {
        const [, filterName, value] = filterMatch;
        const values = filterName === 'type' ? typeValues : filterName === 'person' ? personValues : filterName === 'dossier' ? dossierValues : [];
        const completion = completeFromList(value, values);
        return completion ? `${query.slice(0, tokenStart)}${filterName}:${completion}` : '';
      }

      if (!lowerToken.includes(':') && !lowerToken.includes('"')) {
        const filterName = completeFromList(lowerToken, filterNames);
        if (filterName) return `${query.slice(0, tokenStart)}${filterName}:`;
      }

      const freeStart = trailingFreeRunStart(query);
      if (freeStart === null) return '';
      const completion = titleCompletion(query.slice(freeStart));
      return completion ? `${query.slice(0, freeStart)}${completion}` : '';
    }

    function renderResults(query) {
      const { terms, filters } = parseQuery(query);
      const ranked = items
        .filter((item) => matchesFilters(item, filters))
        .map((item) => ({ item, score: scoreItem(item, terms) }))
        .filter((entry) => entry.score > 0)
        .sort((a, b) => b.score - a.score || Date.parse(b.item.timestamp) - Date.parse(a.item.timestamp))
        .slice(0, 24);

      if (!query.trim()) {
        results.innerHTML = '';
        return;
      }
      if (ranked.length === 0) {
        results.innerHTML = '<p class="no-results">No matching quests found.</p>';
        return;
      }
      results.innerHTML = ranked.map(({ item, score }) => {
        const reasons = matchReasons(item, terms);
        return `
        <article class="result-card">
          <div class="result-meta"><span>${labels[item.type] || item.type}</span><span>${scoreLabel(score, terms)}</span></div>
          <h3>${escapeHtml(item.title)}</h3>
          <p>${escapeHtml(item.subtitle)}</p>
          <p>${escapeHtml(item.excerpt)}</p>
          <small>${escapeHtml(item.path)}</small>
          ${reasons.length ? `<div class="match-reasons">${reasons.map((reason) => `<span>${reason}</span>`).join('')}</div>` : ''}
          <div class="card-actions">
            <a href="${item.sourceUrl}">Open inline</a>
            <a href="${item.obsidianUrl}">Open in Vault</a>
          </div>
        </article>
      `;
      }).join('');
    }

    function updatePanelTitleState(query) {
      const normalizedQuery = query.trim();
      document.querySelectorAll('[data-panel-query]').forEach((button) => {
        const active = button.getAttribute('data-panel-query') === normalizedQuery;
        button.setAttribute('aria-pressed', active ? 'true' : 'false');
        button.dataset.active = active ? 'true' : 'false';
      });
    }

    function setSearchExpression(query) {
      if (!input) return;
      input.value = query;
      renderResults(input.value);
      updatePanelTitleState(input.value);
      input.focus();
    }

    input?.addEventListener('input', () => { renderResults(input.value); updatePanelTitleState(input.value); });
    input?.addEventListener('keydown', (event) => {
      if (event.key !== 'Tab') return;
      if (input.selectionStart !== input.value.length || input.selectionEnd !== input.value.length) return;
      const completion = tabCompletion(input.value);
      if (!completion || completion === input.value) return;
      event.preventDefault();
      input.value = completion;
      renderResults(input.value);
      updatePanelTitleState(input.value);
    });
    clear?.addEventListener('click', () => { input.value = ''; renderResults(''); updatePanelTitleState(''); input.focus(); });
    document.addEventListener('keydown', (event) => {
      if (event.key === '/' && document.activeElement !== input) {
        event.preventDefault();
        input?.focus();
      }
      if (event.key === 'Escape' && document.activeElement === input) {
        input.value = '';
        renderResults('');
        updatePanelTitleState('');
      }
    });
    document.querySelectorAll('[data-lane]').forEach((button) => {
      button.addEventListener('click', () => {
        const lane = button.getAttribute('data-lane');
        setSearchExpression(`type:${lane}`);
      });
    });
    document.querySelectorAll('[data-dossier]').forEach((button) => {
      button.addEventListener('click', () => {
        const dossier = button.getAttribute('data-dossier');
        setSearchExpression(`dossier:${dossier}`);
      });
    });
    document.querySelectorAll('[data-panel-query]').forEach((button) => {
      button.addEventListener('click', () => {
        const query = button.getAttribute('data-panel-query');
        if (query) setSearchExpression(query);
      });
    });
  </script>

  <style>
    :global(body) {
      background:
        radial-gradient(circle at 18% 0%, rgba(224, 83, 28, 0.22), transparent 28rem),
        radial-gradient(circle at 90% 12%, rgba(120, 82, 190, 0.22), transparent 24rem),
        var(--bg);
    }

    .dashboard-shell {
      --purple: #8d67ff;
      --green: #80c56c;
      --panel: #1b1511;
      --panel-2: #241a15;
      --bevel-light: rgba(242, 234, 219, 0.18);
      --bevel-dark: rgba(0, 0, 0, 0.48);
      width: min(1480px, calc(100vw - 24px));
      margin: 0 auto;
      padding: 1.2rem 0 4rem;
      font-family: var(--font-sans);
      overflow-x: clip;
    }

    .dashboard-shell *,
    .dashboard-shell *::before,
    .dashboard-shell *::after {
      box-sizing: border-box;
    }

    .hero-panel,
    .search-console,
    .lane-card,
    .activity-card,
    .side-panel {
      border: 2px solid var(--border);
      box-shadow: inset 2px 2px 0 var(--bevel-light), inset -2px -2px 0 var(--bevel-dark), 0 18px 70px rgba(0, 0, 0, 0.32);
      background: linear-gradient(145deg, rgba(36, 26, 21, 0.96), rgba(16, 11, 10, 0.98));
    }

    .hero-panel {
      position: relative;
      overflow: hidden;
      padding: clamp(1rem, 2.2vw, 2rem);
      margin-bottom: 1rem;
    }

    .scanline {
      position: absolute;
      inset: 0;
      pointer-events: none;
      opacity: 0.09;
      background: repeating-linear-gradient(0deg, transparent, transparent 3px, var(--ink) 4px);
    }

    .hero-topline,
    .console-titlebar {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .boot-chip {
      border: 1px solid rgba(224, 83, 28, 0.5);
      color: var(--gold);
      padding: 0.25rem 0.55rem;
      background: rgba(224, 83, 28, 0.09);
      overflow-wrap: anywhere;
    }

    .boot-chip.purple { border-color: rgba(141, 103, 255, 0.7); color: var(--purple); }

    .hero-grid {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: clamp(1rem, 2.6vw, 2rem);
      align-items: center;
    }

    .hero-mark {
      color: var(--primary);
      filter: drop-shadow(0 0 18px rgba(224, 83, 28, 0.58));
    }

    .eyebrow,
    .section-heading p,
    .search-label {
      color: var(--green);
      font-size: 0.76rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      font-weight: 700;
    }

    h1 {
      font-size: clamp(2.4rem, 8vw, 6.4rem);
      line-height: 0.9;
      letter-spacing: -0.06em;
      color: var(--ink);
      text-shadow: 4px 4px 0 rgba(224, 83, 28, 0.34), 8px 8px 0 rgba(141, 103, 255, 0.18);
    }

    .hero-copy {
      max-width: 62ch;
      margin-top: 0.8rem;
      color: var(--muted);
      font-size: clamp(1rem, 2vw, 1.25rem);
    }

    .save-stats {
      display: grid;
      gap: 0.55rem;
      min-width: 180px;
    }

    .save-stats div {
      border: 1px solid var(--border);
      background: rgba(15, 11, 10, 0.6);
      padding: 0.65rem;
      display: grid;
      min-width: 0;
    }

    .save-stats strong { color: var(--primary); font-size: 1.65rem; line-height: 1; }
    .save-stats span { color: var(--muted); font-size: 0.76rem; text-transform: uppercase; overflow-wrap: anywhere; }

    .search-console {
      padding: 1rem;
      margin-bottom: 1rem;
      border-color: rgba(141, 103, 255, 0.55);
    }

    .console-titlebar {
      background: linear-gradient(90deg, rgba(141, 103, 255, 0.32), rgba(224, 83, 28, 0.22));
      border: 1px solid rgba(242, 234, 219, 0.14);
      padding: 0.35rem 0.55rem;
    }

    .search-row {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 0.65rem;
      align-items: center;
      margin-top: 0.5rem;
      background: #080605;
      border: 2px inset var(--border);
      padding: 0.65rem;
    }

    .prompt {
      color: var(--primary);
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-weight: 800;
    }

    #vault-search {
      background: transparent;
      border: 0;
      color: var(--ink);
      font: 700 1rem ui-monospace, SFMono-Regular, Menlo, monospace;
      outline: none;
      min-width: 0;
    }

    #vault-search::placeholder { color: rgba(242, 234, 219, 0.38); }

    #clear-search,
    .lane-card,
    .card-actions a {
      cursor: pointer;
      background: var(--panel-2);
      color: var(--ink);
      border: 2px outset var(--border);
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    #clear-search { padding: 0.35rem 0.55rem; }
    #clear-search:hover, .card-actions a:hover { color: #080605; background: var(--primary); opacity: 1; }

    .search-help { color: var(--muted); margin-top: 0.55rem; font-size: 0.85rem; }
    kbd, code { color: var(--gold); }

    .search-results {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(280px, 100%), 1fr));
      gap: 0.75rem;
      margin-top: 0.9rem;
    }

    .result-card {
      border: 1px solid rgba(141, 103, 255, 0.42);
      background: rgba(8, 6, 5, 0.8);
      padding: 0.85rem;
    }

    .result-meta { display: flex; justify-content: space-between; color: var(--purple); font-size: 0.72rem; text-transform: uppercase; }
    .result-card h3 { margin-top: 0.35rem; color: var(--ink); }
    .result-card p { color: var(--muted); font-size: 0.9rem; }
    .result-card small { display: block; color: rgba(242, 234, 219, 0.48); margin-top: 0.35rem; overflow-wrap: anywhere; }
    .match-reasons { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.55rem; }
    .match-reasons span { border: 1px solid rgba(128, 197, 108, 0.45); color: #80c56c; background: rgba(128, 197, 108, 0.08); padding: 0.12rem 0.35rem; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.08em; }

    .lane-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(180px, 100%), 1fr));
      gap: 0.75rem;
      margin-bottom: 1.2rem;
    }

    .lane-card {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      align-items: center;
      gap: 0.7rem;
      padding: 0.85rem;
      text-align: left;
    }

    .lane-card:hover { transform: translateY(-2px); border-color: var(--primary); }
    .lane-glyph { color: var(--primary); font-size: 1.4rem; }
    .lane-text { display: grid; min-width: 0; }
    .lane-text strong { overflow-wrap: anywhere; }
    .lane-text em { color: var(--muted); font-size: 0.73rem; font-style: normal; text-transform: none; letter-spacing: 0; }
    .lane-count { color: var(--gold); font-size: 1.25rem; justify-self: end; }

    .main-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 360px;
      gap: 1rem;
      align-items: start;
    }

    .section-heading h2 {
      font-size: clamp(1.8rem, 4vw, 3rem);
      margin-bottom: 0.75rem;
    }

    .activity-list,
    .side-panels {
      display: grid;
      gap: 0.85rem;
      min-width: 0;
    }

    .quest-log { min-width: 0; }

    .activity-card {
      display: grid;
      grid-template-columns: 128px 1fr;
      min-width: 0;
      overflow: hidden;
    }

    .card-rarity {
      display: grid;
      place-items: center;
      padding: 0.75rem;
      writing-mode: vertical-rl;
      text-orientation: mixed;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: #080605;
      background: var(--primary);
      font-weight: 900;
      font-size: 0.76rem;
    }

    .type-dream .card-rarity { background: var(--purple); color: var(--ink); }
    .type-sias-lens .card-rarity { background: var(--gold); }
    .type-conversation .card-rarity { background: var(--green); }
    .type-daemon-status .card-rarity { background: #c46874; color: var(--ink); }
    .type-registry-project .card-rarity { background: #8d67ff; color: var(--ink); }
    .type-registry-service .card-rarity { background: #62b6a8; color: #080605; }
    .type-repo-activity .card-rarity { background: #d6a85f; color: #080605; }

    .card-main { padding: 1rem; min-width: 0; }
    .card-main time { color: var(--gold); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.12em; }
    .card-main h3 { margin-top: 0.2rem; font-size: 1.45rem; overflow-wrap: anywhere; }
    .subtitle { color: var(--primary); font-weight: 700; }
    .excerpt { color: var(--muted); margin-top: 0.45rem; }
    .path { color: rgba(242, 234, 219, 0.45); font-size: 0.78rem; margin-top: 0.5rem; overflow-wrap: anywhere; }

    .card-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.8rem;
    }

    .card-actions a {
      display: inline-flex;
      padding: 0.42rem 0.62rem;
      color: var(--ink);
      font-size: 0.72rem;
      text-decoration: none;
    }

    .side-panel { padding: 1rem; min-width: 0; }
    .panel-title { color: var(--primary); font-weight: 900; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 0.7rem; }
    .panel-title-button {
      display: block;
      width: 100%;
      padding: 0;
      border: 0;
      background: transparent;
      text-align: left;
      font-family: inherit;
      font-size: inherit;
      cursor: pointer;
    }
    .panel-title-button:hover,
    .panel-title-button:focus-visible,
    .panel-title-button[data-active='true'] {
      color: var(--gold);
      text-shadow: 0 0 12px rgba(214, 168, 95, 0.45);
      outline: none;
    }
    .panel-title-button[data-active='true']::before { content: '▶ '; }
    .side-panel a { color: inherit; text-decoration: none; }
    .oracle a { display: grid; gap: 0.35rem; }
    .oracle time { color: var(--gold); font-size: 0.75rem; }
    .oracle span { color: var(--muted); font-size: 0.9rem; }

    .mini-row,
    .daemon-row {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 0.65rem;
      align-items: center;
      padding: 0.55rem 0;
      border-top: 1px solid rgba(242, 234, 219, 0.08);
    }

    .mini-row span:last-child,
    .daemon-row span:last-child {
      min-width: 0;
    }

    .mini-row strong,
    .daemon-row strong {
      display: block;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .mini-row em,
    .daemon-row em { display: block; color: var(--muted); font-style: normal; font-size: 0.78rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .avatar { display: grid; place-items: center; width: 2rem; height: 2rem; background: var(--purple); color: var(--ink); font-weight: 900; border: 2px outset rgba(242, 234, 219, 0.2); }
    .pixel-dot, .health { width: 0.85rem; height: 0.85rem; background: var(--green); box-shadow: 0 0 12px rgba(128, 197, 108, 0.7); }
    .health.stale,
    .health.unknown { background: var(--gold); box-shadow: 0 0 12px rgba(214, 168, 95, 0.55); }
    .health.down { background: #c46874; box-shadow: 0 0 12px rgba(196, 104, 116, 0.7); }

    .no-results { color: var(--muted); }

    @media (max-width: 980px) {
      .hero-grid,
      .main-grid { grid-template-columns: 1fr; }
      .hero-mark { display: none; }
      .save-stats { grid-template-columns: repeat(3, 1fr); }
      .activity-card { grid-template-columns: 1fr; }
      .card-rarity { writing-mode: horizontal-tb; }
    }

    @media (max-width: 620px) {
      .dashboard-shell { width: min(100vw - 14px, 1480px); }
      .search-row { grid-template-columns: 1fr; }
      .prompt { display: none; }
      .save-stats { grid-template-columns: 1fr; }
      .lane-card { grid-template-columns: auto minmax(0, 1fr); }
      .lane-count { grid-column: 2; justify-self: start; }
    }

    @media (max-width: 420px) {
      .dashboard-shell { width: min(100vw - 10px, 1480px); }
      .hero-panel,
      .search-console,
      .side-panel { padding: 0.75rem; }
      .lane-card { padding: 0.7rem; gap: 0.55rem; }
      .card-main { padding: 0.8rem; }
      .card-main h3 { font-size: 1.2rem; }
      .hero-topline,
      .console-titlebar { justify-content: flex-start; }
    }
  </style>
</DashboardLayout>

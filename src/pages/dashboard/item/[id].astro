---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import RupicolaMark from '../../../components/RupicolaMark.astro';
import dashboardData from '../../../data/vault-dashboard.json';

type ActivityItem = {
  id: string;
  type: string;
  title: string;
  subtitle: string;
  timestamp: string;
  path: string;
  tags: string[];
  excerpt: string;
  html: string;
  obsidianUrl: string;
  person?: string;
  summary: {
    status: 'cached' | 'generated' | 'error';
    summary: string;
    key_points: string[];
    action_items: string[];
    tags: string[];
    updated_at: string;
  };
};

export function getStaticPaths() {
  return (dashboardData.items as ActivityItem[]).map((item) => ({ params: { id: item.id }, props: { item } }));
}

const { item } = Astro.props as { item: ActivityItem };
const date = new Date(item.timestamp);
const formattedDate = date.toLocaleDateString('en-GB', { month: 'long', day: '2-digit', year: 'numeric' });
const formattedTime = date.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
---

<DashboardLayout title={item.title} description={item.subtitle} canonicalUrl={`https://vault.dyallo.se/dashboard/item/${item.id}`}>
  <main class="item-shell" data-pagefind-ignore>
    <nav class="crumbs" aria-label="Dashboard breadcrumb">
      <a href="/dashboard">← Vault Quest Log</a>
      <span>/</span>
      <span>{item.type}</span>
    </nav>

    <article class="item-window">
      <header class="item-header">
        <div class="window-bar">
          <span>INLINE_VIEW.EXE</span>
          <span>{formattedDate} {formattedTime}</span>
        </div>
        <div class="title-row">
          <div class="mark" aria-hidden="true"><RupicolaMark size={72} /></div>
          <div>
            <p class="type-chip">{item.type}{item.person ? ` · ${item.person}` : ''}</p>
            <h1>{item.title}</h1>
            <p>{item.subtitle}</p>
          </div>
        </div>
        <div class="actions">
          <a href={item.obsidianUrl}>Open in Vault</a>
          <a href="/dashboard">Return to dashboard</a>
        </div>
        <dl class="meta-grid">
          <div><dt>Path</dt><dd>{item.path}</dd></div>
          <div><dt>Tags</dt><dd>{item.tags.length ? item.tags.join(', ') : 'none'}</dd></div>
        </dl>
      </header>

      <section class:list={['summary-panel', `status-${item.summary.status}`]} aria-labelledby="summary-title">
        <div class="summary-topline">
          <p id="summary-title">Auto Brief</p>
          <span>{item.summary.status === 'cached' ? 'cached sidecar' : item.summary.status === 'generated' ? 'generated sidecar' : 'sidecar fallback'}</span>
        </div>
        <p class="summary-copy">{item.summary.summary}</p>
        <div class="summary-grid">
          <div>
            <h2>Key Points</h2>
            <ul>
              {item.summary.key_points.map((point) => <li>{point}</li>)}
            </ul>
          </div>
          <div>
            <h2>Action Items</h2>
            {item.summary.action_items.length ? (
              <ul>{item.summary.action_items.map((action) => <li>{action}</li>)}</ul>
            ) : (
              <p class="empty-state">No explicit action items detected.</p>
            )}
          </div>
        </div>
      </section>

      <section class="markdown-body" set:html={item.html} />
    </article>
  </main>

  <style>
    :global(body) {
      background:
        radial-gradient(circle at 12% 0%, rgba(224, 83, 28, 0.2), transparent 26rem),
        radial-gradient(circle at 86% 8%, rgba(141, 103, 255, 0.2), transparent 24rem),
        var(--bg);
    }

    .item-shell {
      width: min(980px, calc(100vw - 24px));
      margin: 0 auto;
      padding: 1.5rem 0 4rem;
    }

    .crumbs {
      display: flex;
      gap: 0.5rem;
      align-items: center;
      color: var(--muted);
      font-size: 0.86rem;
      margin-bottom: 1rem;
    }

    .crumbs a { color: var(--primary); }

    .item-window {
      border: 2px solid var(--border);
      background: linear-gradient(145deg, rgba(36, 26, 21, 0.97), rgba(15, 11, 10, 0.99));
      box-shadow: inset 2px 2px 0 rgba(242, 234, 219, 0.16), inset -2px -2px 0 rgba(0, 0, 0, 0.5), 0 18px 70px rgba(0, 0, 0, 0.35);
    }

    .window-bar {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      padding: 0.45rem 0.7rem;
      background: linear-gradient(90deg, rgba(141, 103, 255, 0.35), rgba(224, 83, 28, 0.24));
      border-bottom: 1px solid rgba(242, 234, 219, 0.12);
      color: var(--ink);
      font: 800 0.72rem ui-monospace, SFMono-Regular, Menlo, monospace;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .item-header { padding: clamp(1rem, 3vw, 2rem); border-bottom: 1px solid var(--border); }
    .title-row { display: grid; grid-template-columns: auto 1fr; gap: 1rem; align-items: start; }
    .mark { color: var(--primary); filter: drop-shadow(0 0 14px rgba(224, 83, 28, 0.55)); }
    .type-chip { color: #80c56c; text-transform: uppercase; letter-spacing: 0.14em; font-weight: 900; font-size: 0.75rem; }
    h1 { font-size: clamp(2.1rem, 6vw, 4.4rem); line-height: 0.95; letter-spacing: -0.04em; text-shadow: 3px 3px 0 rgba(224, 83, 28, 0.28); }
    .title-row p:last-child { color: var(--muted); margin-top: 0.5rem; font-size: 1.1rem; }

    .actions { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 1rem; }
    .actions a {
      border: 2px outset var(--border);
      background: #241a15;
      color: var(--ink);
      padding: 0.45rem 0.7rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.76rem;
    }
    .actions a:hover { background: var(--primary); color: #080605; opacity: 1; }

    .meta-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 0.75rem;
      margin-top: 1rem;
    }
    .meta-grid div { border: 1px solid var(--border); padding: 0.7rem; background: rgba(8, 6, 5, 0.55); }
    dt { color: var(--primary); font-weight: 900; text-transform: uppercase; font-size: 0.72rem; letter-spacing: 0.12em; }
    dd { color: var(--muted); overflow-wrap: anywhere; }

    .summary-panel {
      margin: clamp(1rem, 3vw, 2rem);
      margin-bottom: 0;
      border: 2px solid rgba(214, 168, 95, 0.58);
      background:
        linear-gradient(135deg, rgba(214, 168, 95, 0.13), rgba(141, 103, 255, 0.12)),
        rgba(8, 6, 5, 0.64);
      box-shadow: inset 2px 2px 0 rgba(242, 234, 219, 0.12), inset -2px -2px 0 rgba(0, 0, 0, 0.45);
      padding: clamp(0.9rem, 2.4vw, 1.3rem);
    }

    .summary-topline {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      color: var(--gold);
      font: 900 0.72rem ui-monospace, SFMono-Regular, Menlo, monospace;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .summary-topline span { color: #80c56c; }
    .status-error .summary-topline span { color: #c46874; }

    .summary-copy {
      margin: 0.75rem 0 1rem;
      color: var(--ink);
      line-height: 1.7;
      font-size: 1.05rem;
    }

    .summary-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .summary-grid h2 {
      color: var(--primary);
      font-size: 0.82rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-bottom: 0.35rem;
    }

    .summary-grid ul { margin: 0; padding-left: 1.1rem; }
    .summary-grid li,
    .empty-state { color: var(--muted); line-height: 1.55; margin: 0.35rem 0; }

    .markdown-body {
      padding: clamp(1rem, 3vw, 2rem);
      max-width: 76ch;
      color: var(--ink);
    }

    .markdown-body :global(h1),
    .markdown-body :global(h2),
    .markdown-body :global(h3) {
      margin: 1.5rem 0 0.55rem;
      color: var(--ink);
      text-shadow: none;
      letter-spacing: 0;
    }
    .markdown-body :global(h1) { font-size: 2rem; }
    .markdown-body :global(h2) { font-size: 1.55rem; color: var(--gold); }
    .markdown-body :global(h3) { font-size: 1.25rem; color: var(--primary); }
    .markdown-body :global(p),
    .markdown-body :global(li),
    .markdown-body :global(blockquote) { margin: 0.75rem 0; color: var(--ink); line-height: 1.75; }
    .markdown-body :global(ul) { padding-left: 1.2rem; margin: 0.75rem 0; }
    .markdown-body :global(strong) { color: var(--gold); }
    .markdown-body :global(code) { color: #80c56c; background: rgba(8, 6, 5, 0.72); padding: 0.1rem 0.25rem; }
    .markdown-body :global(pre) { overflow: auto; background: #080605; border: 1px solid var(--border); padding: 1rem; }
    .markdown-body :global(blockquote) { border-left: 3px solid var(--primary); padding-left: 1rem; color: var(--muted); }

    @media (max-width: 640px) {
      .title-row { grid-template-columns: 1fr; }
      .mark { display: none; }
      .window-bar { display: grid; }
      .summary-grid { grid-template-columns: 1fr; }
    }
  </style>
</DashboardLayout>

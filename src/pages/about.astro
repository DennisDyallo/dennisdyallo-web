---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="The convergence of engineering, music, coaching, and writing.">
  <div class="container">
    <h1>About</h1>
    <div class="content">
      <p>
        The four registers — engineering, music, coaching, writing — are not separate practices.
        They're one throughline: building systems for human sovereignty.
      </p>
      <p>
        <em>Full narrative coming in Phase 2.</em>
      </p>
    </div>
  </div>

  <style>
    .container {
      max-width: var(--reading-width);
      margin: 0 auto;
      padding: var(--space-2xl) var(--space-lg);
    }

    h1 {
      font-size: 2.5rem;
      margin-bottom: var(--space-xl);
    }

    .content p {
      font-size: 1.1rem;
      line-height: 1.7;
      margin-bottom: var(--space-lg);
      color: var(--muted);
    }

    .content em {
      color: var(--muted);
      font-style: italic;
    }
  </style>
</BaseLayout>

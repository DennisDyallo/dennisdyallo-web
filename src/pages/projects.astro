---
import BaseLayout from '../layouts/BaseLayout.astro';

const cases = [
  {
    title: 'dyallo.se',
    problem: 'The old site had a clear voice, but no durable publishing system and no visible structure for the four-register convergence.',
    approach: 'Rebuild as an Astro static site with register pages, blog content collections, RSS, sitemap, Satori OG images, Buttondown subscription, and a vault-to-site workflow.',
    outcome: 'A single public surface where engineering, music, coaching, projects, and writing can compound under one domain.',
    tech: 'Astro, TypeScript, Bun, Satori, Sharp, Buttondown, Caddy',
    href: 'https://dyallo.se',
    repo: 'https://github.com/DennisDyallo/dennisdyallo-web',
  },
  {
    title: 'PAI (personal Sia fork)',
    problem: 'AI assistants are powerful, but without memory, local context, and clear operating principles they become another rented interface.',
    approach: 'Fork the PAI framework and shape it around Sia as a daily AI peer — memory, workflows, agent handoffs, publishing, and Dennis-owned context.',
    outcome: 'A sovereignty-aligned operating system for personal work, evolving in the open and selectively surfaced through writing.',
    tech: 'TypeScript, Bun, local tooling, agent workflows, markdown, structured prompts',
    href: '/blog/hello-blog',
    repo: 'https://github.com/DennisDyallo/Personal_AI_Infrastructure',
  },
  {
    title: 'Speaksheet',
    problem: 'Gigging musicians and worship leaders work from chord sheets that are awkward on phones — small text, poor edit affordances, no scroll/zoom intuition.',
    approach: 'Build a mobile-first chord-sheet app (Svelte 5 + Capacitor) with edit mode, autoscroll, BPM, dictation, and a layout stability contract enforced by audit scripts.',
    outcome: 'Preparing for Play Store release. Codebase doubles as the field site for the engineer-vs-codex AI routing experiment written up on the blog.',
    tech: 'Svelte 5, Capacitor, TypeScript, Biome, Vitest',
    href: '/blog/engineer-vs-codex-routing-pattern',
  },
  {
    title: 'echological.fm',
    problem: 'Artists working between tradition and contemporary expression need infrastructure that translates their work without flattening it.',
    approach: 'Build artist pages, EPK material, booking narrative, and lightweight operational systems around a carefully chosen roster.',
    outcome: 'A clearer management surface for Hazayana, Naomi Runa, Andreas Lång, Sophie von Matern, and Felicia Falck.',
    tech: 'Web publishing, artist narrative, booking systems, media assets',
    href: 'https://echological.fm',
  },
];
---

<BaseLayout title="Projects" description="Case studies in sovereignty-aligned systems, publishing, and artist infrastructure.">
  <main class="container">
    <figure class="page-hero" aria-hidden="true">
      <img src="/heroes/projects.webp" srcset="/heroes/projects-sm.webp 800w, /heroes/projects.webp 1600w" sizes="(max-width: 900px) 100vw, 860px" width="1600" height="900" alt="" loading="eager" fetchpriority="high" />
    </figure>
    <header class="page-header">
      <p class="eyebrow">Projects</p>
      <h1>Case studies in systems that make people more sovereign.</h1>
      <p>Some projects are code. Some are artist infrastructure. Some are public surfaces for a private operating system. The common measure is whether the system returns agency to the person using it.</p>
    </header>

    <div class="case-list">
      {cases.map((item) => (
        <article class="case-card">
          <h2>{item.title}</h2>
          <dl>
            <dt>Problem</dt><dd>{item.problem}</dd>
            <dt>Approach</dt><dd>{item.approach}</dd>
            <dt>Outcome</dt><dd>{item.outcome}</dd>
            <dt>Tech</dt><dd>{item.tech}</dd>
          </dl>
          <div class="case-links">
            <a href={item.href}>View project</a>
            {item.repo && <a href={item.repo} target="_blank" rel="noopener">github ↗</a>}
          </div>
        </article>
      ))}
    </div>
  </main>

  <style>
    .container { max-width: 980px; margin: 0 auto; padding: var(--space-3xl) var(--space-lg); }
    .page-header { max-width: 780px; margin-bottom: var(--space-2xl); }
    .eyebrow { color: var(--gold); font-size: var(--type-small); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: var(--space-sm); }
    h1 { font-size: var(--type-h1); margin-bottom: var(--space-md); }
    .page-header p { color: var(--muted); line-height: 1.65; }
    .case-list { display: grid; gap: var(--space-xl); }
    .case-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); padding: var(--space-xl); }
    h2 { font-size: var(--type-h3); margin-bottom: var(--space-lg); }
    dl { display: grid; grid-template-columns: 7rem 1fr; gap: var(--space-sm) var(--space-lg); margin-bottom: var(--space-lg); }
    dt { color: var(--gold); font-size: var(--type-small); text-transform: uppercase; letter-spacing: 0.06em; }
    dd { color: var(--muted); line-height: 1.6; }
    .case-links { display: flex; gap: var(--space-lg); align-items: center; }
    .case-links a { color: var(--primary); }
    .case-links a:last-child:not(:first-child) { color: var(--gold); font-size: var(--type-small); text-transform: uppercase; letter-spacing: 0.06em; }
    .case-links a:last-child:hover { color: var(--primary); }
    @media (max-width: 768px) { h1 { font-size: var(--type-h2); } dl { grid-template-columns: 1fr; gap: var(--space-xs); } dd { margin-bottom: var(--space-sm); } }
    .page-hero { margin: 0 0 var(--space-2xl); border-radius: var(--radius-md); overflow: hidden; aspect-ratio: 16 / 9; background: var(--surface); }
    .page-hero img { display: block; width: 100%; height: 100%; object-fit: cover; }

  </style>
</BaseLayout>

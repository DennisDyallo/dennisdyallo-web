---
import { rupicolaSvg } from '../lib/rupicola';

interface Props {
  size?: number;
  label?: string;
}

// `size` is interpreted as HEIGHT in px; width derives from SVG's natural aspect ratio (~733/1024).
// This keeps the bird flush against its bounding box with no internal whitespace padding.
const { size = 24, label = 'Rupicola signature mark' } = Astro.props;
---

<span
  class="rupicola-mark"
  role="img"
  aria-label={label}
  style={`--mark-size: ${size}px`}
  set:html={rupicolaSvg}
/>

<style>
  .rupicola-mark {
    display: inline-block;
    height: var(--mark-size);
    width: auto;
    color: currentColor;
    line-height: 0;
    vertical-align: top;
  }

  .rupicola-mark :global(svg) {
    display: block;
    height: 100%;
    width: auto;
  }
</style>

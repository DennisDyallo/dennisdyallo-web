---
// DotSequence — Original geometric ornament
// Rhythmic dots suggesting punctuation, breath, pause
// Single-color, controlled repetition, restraint
const { class: className = '' } = Astro.props;
---

<svg class={`ornament ${className}`} width="80" height="20" viewBox="0 0 80 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <title>Dot Sequence Ornament</title>
  <!-- Small dots -->
  <circle cx="10" cy="10" r="1.5" fill="currentColor"/>
  <circle cx="20" cy="10" r="1.5" fill="currentColor"/>

  <!-- Medium dot (center emphasis) -->
  <circle cx="30" cy="10" r="2.5" fill="currentColor"/>
  <circle cx="40" cy="10" r="3" fill="currentColor"/>
  <circle cx="50" cy="10" r="2.5" fill="currentColor"/>

  <!-- Small dots -->
  <circle cx="60" cy="10" r="1.5" fill="currentColor"/>
  <circle cx="70" cy="10" r="1.5" fill="currentColor"/>
</svg>

<style>
  .ornament {
    display: block;
    margin: 0 auto;
    color: var(--muted);
    opacity: 0.6;
  }
</style>

---
// StepPattern — Original geometric ornament
// Ascending stepped lines suggesting progression, growth
// Single-color, controlled repetition, restraint
const { class: className = '' } = Astro.props;
---

<svg class={`ornament ${className}`} width="120" height="40" viewBox="0 0 120 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <title>Step Pattern Ornament</title>
  <!-- First step -->
  <line x1="10" y1="30" x2="20" y2="30" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="20" y1="30" x2="20" y2="25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>

  <!-- Second step -->
  <line x1="20" y1="25" x2="30" y2="25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="30" y1="25" x2="30" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>

  <!-- Third step (center peak) -->
  <line x1="30" y1="20" x2="40" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="40" y1="20" x2="40" y2="15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="40" y1="15" x2="50" y2="15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="50" y1="15" x2="50" y2="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>

  <!-- Center point -->
  <circle cx="60" cy="10" r="2" fill="currentColor"/>

  <!-- Descending steps (mirror) -->
  <line x1="70" y1="10" x2="70" y2="15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="70" y1="15" x2="80" y2="15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="80" y1="15" x2="80" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>

  <line x1="80" y1="20" x2="90" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="90" y1="20" x2="90" y2="25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>

  <line x1="90" y1="25" x2="100" y2="25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="100" y1="25" x2="100" y2="30" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="100" y1="30" x2="110" y2="30" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
</svg>

<style>
  .ornament {
    display: block;
    margin: 0 auto;
    color: var(--border);
  }
</style>

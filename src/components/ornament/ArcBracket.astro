---
// ArcBracket — Original geometric ornament
// Paired arcs creating containment, framing, closure
// Single-color, controlled repetition, restraint
const { class: className = '' } = Astro.props;
---

<svg class={`ornament ${className}`} width="100" height="24" viewBox="0 0 100 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <!-- Left bracket -->
  <path d="M 15 4 Q 10 12 15 20" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
  <line x1="15" y1="4" x2="20" y2="4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="15" y1="20" x2="20" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>

  <!-- Center mark -->
  <circle cx="50" cy="12" r="2" fill="currentColor"/>

  <!-- Right bracket (mirrored) -->
  <path d="M 85 4 Q 90 12 85 20" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
  <line x1="85" y1="4" x2="80" y2="4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="85" y1="20" x2="80" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
</svg>

<style>
  .ornament {
    display: block;
    margin: 0 auto;
    color: var(--primary);
    opacity: 0.4;
  }
</style>

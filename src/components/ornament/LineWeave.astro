---
// LineWeave — Original geometric ornament
// Interlaced horizontal lines suggesting weaving, integration
// Single-color, controlled repetition, restraint
const { class: className = '' } = Astro.props;
---

<svg class={`ornament ${className}`} width="160" height="32" viewBox="0 0 160 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <title>Line Weave Ornament</title>
  <!-- Top line with breaks -->
  <line x1="10" y1="10" x2="40" y2="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="50" y1="10" x2="70" y2="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="80" y1="10" x2="110" y2="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="120" y1="10" x2="150" y2="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>

  <!-- Middle line (offset breaks) -->
  <line x1="10" y1="16" x2="30" y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="40" y1="16" x2="80" y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="90" y1="16" x2="130" y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="140" y1="16" x2="150" y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>

  <!-- Bottom line (different rhythm) -->
  <line x1="10" y1="22" x2="50" y2="22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="60" y1="22" x2="100" y2="22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="110" y1="22" x2="150" y2="22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>

  <!-- Vertical connectors (subtle) -->
  <line x1="40" y1="10" x2="40" y2="22" stroke="currentColor" stroke-width="0.75" opacity="0.3"/>
  <line x1="110" y1="10" x2="110" y2="22" stroke="currentColor" stroke-width="0.75" opacity="0.3"/>
</svg>

<style>
  .ornament {
    display: block;
    margin: 0 auto;
    color: var(--border);
  }
</style>
